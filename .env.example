# TALOS — Template `.env` (committed, documenta le env var supportate).
#
# Copia questo file in `.env` (gitignored) e popola i valori reali:
#   cp .env.example .env
#
# `TalosSettings` (src/talos/config/settings.py) legge `.env` nel cwd via
# pydantic-settings al boot. Le env var dirette dalla shell/CI hanno
# PRECEDENZA su `.env`.
#
# Tutti i campi sono OPZIONALI a livello di import: il modulo si importa
# senza fallire anche se le env non sono settate. Il fail-fast avviene al
# call site (es. `KeepaClient.fetch_*` quando key=None -> errore esplicito).

# ---- Database (PostgreSQL) ----
# URL pool app (talos_app role, NOBYPASSRLS).
# TALOS_DB_URL=postgresql+psycopg://talos_app:CHANGE_ME@localhost:5432/talos
# URL superuser per scripts/db_bootstrap.py (creazione ruoli + RLS).
# TALOS_DB_URL_SUPERUSER=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/postgres
# Password ruoli (lette da scripts/db_bootstrap.py).
# TALOS_ADMIN_PASSWORD=CHANGE_ME
# TALOS_APP_PASSWORD=CHANGE_ME
# TALOS_AUDIT_PASSWORD=CHANGE_ME

# ---- Soglie applicative (override config_overrides DB-side se presente) ----
# TALOS_ROI_VETO_THRESHOLD=0.08

# ---- Keepa API (canale 1 acquisizione, ADR-0017) ----
# Private API access key (https://keepa.com/#!api).
# TALOS_KEEPA_API_KEY=CHANGE_ME
# Limite hard richieste/min (R-01 NO SILENT DROPS sul superamento).
# TALOS_KEEPA_RATE_LIMIT_PER_MINUTE=60

# ---- OCR Tesseract (canale 3, ADR-0017) ----
# Soglia confidence Tesseract 0-100. Sotto soglia -> AMBIGUOUS.
# TALOS_OCR_CONFIDENCE_THRESHOLD=70
