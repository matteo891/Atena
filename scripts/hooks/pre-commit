#!/bin/bash
# ADR-0006: Git Hooks Enforcement
# Verifica (1) change document, (2) struttura ADR prima di ogni commit.
# Esteso da:
#   - ADR-0014 (Errata Corrige ADR-0006, CHG-2026-04-30-003): se in staging
#     ci sono file Python/pyproject, dopo i check governance invoca
#     scripts/hooks/pre-commit-app (lint+type+unit). Graceful skip se assente.

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
[ -z "$STAGED" ] && exit 0

# ── Classifica i file in staging ──────────────────────────────────────────────
NON_TRIVIAL_FILES=()
NEW_ADR_FILES=()
HAS_PYTHON_STAGED=0

while IFS= read -r f; do
    [ -z "$f" ] && continue
    # ADR files (subset dei non-triviali, ma gestiti separatamente)
    if echo "$f" | grep -qE '^docs/decisions/ADR-[0-9]+-.*\.md$'; then
        NEW_ADR_FILES+=("$f")
    # File triviali: solo .md, docs/, .claude/, .gitnexus/, gitconfig
    elif ! echo "$f" | grep -qE '(\.md$|^docs/|^\.claude/|^\.gitnexus/|^\.gitignore$|^\.gitattributes$)'; then
        NON_TRIVIAL_FILES+=("$f")
    fi
    # Tracciamento file Python/pyproject per hook applicativo (ADR-0014)
    if echo "$f" | grep -qE '(\.py$|^pyproject\.toml$|^uv\.lock$)'; then
        HAS_PYTHON_STAGED=1
    fi
done <<< "$STAGED"

# ── Check 1: Change Document obbligatorio (ADR-0002, ADR-0004) ────────────────
if [ ${#NON_TRIVIAL_FILES[@]} -gt 0 ]; then
    TODAY=$(date +%Y-%m-%d)
    CHANGE_DOC_FOUND=$(find docs/changes -maxdepth 1 -name "${TODAY}-*.md" \
        ! -name "TEMPLATE.md" 2>/dev/null | head -1)

    if [ -z "$CHANGE_DOC_FOUND" ]; then
        echo ""
        echo "ERROR: COMMIT BLOCCATO — ADR-0002 + ADR-0004"
        echo "──────────────────────────────────────────────────────"
        echo "File non-triviali in staging:"
        for f in "${NON_TRIVIAL_FILES[@]}"; do
            echo "  • $f"
        done
        echo ""
        echo "Nessun change document trovato per oggi ($TODAY)."
        echo ""
        echo "Soluzione:"
        echo "  1. Crea docs/changes/${TODAY}-NNN-slug.md"
        echo "     (usa docs/changes/TEMPLATE.md come base)"
        echo "  2. Esegui i test (ADR-0002)"
        echo "  3. Richiedi permesso al Leader"
        echo "  4. Riprova il commit"
        echo "──────────────────────────────────────────────────────"
        echo ""
        exit 1
    fi
fi

# ── Check 2: Struttura ADR (ADR-0001) ─────────────────────────────────────────
if [ ${#NEW_ADR_FILES[@]} -gt 0 ]; then
    REQUIRED=("## Contesto" "## Decisione" "## Conseguenze" "## Test di Conformità" "## Cross-References" "## Rollback")

    for adr in "${NEW_ADR_FILES[@]}"; do
        MISSING_SECTIONS=()

        for section in "${REQUIRED[@]}"; do
            if ! grep -q "^${section}" "$adr" 2>/dev/null; then
                MISSING_SECTIONS+=("$section")
            fi
        done

        if [ ${#MISSING_SECTIONS[@]} -gt 0 ]; then
            echo ""
            echo "ERROR: COMMIT BLOCCATO — ADR-0001 (struttura ADR)"
            echo "──────────────────────────────────────────────────────"
            echo "ADR malformato: $adr"
            echo "Sezioni mancanti:"
            for s in "${MISSING_SECTIONS[@]}"; do
                echo "  • $s"
            done
            echo ""
            echo "Consulta docs/decisions/TEMPLATE.md per il formato corretto."
            echo "──────────────────────────────────────────────────────"
            echo ""
            exit 1
        fi

        # Verifica presenza in INDEX.md
        ADR_ID=$(grep -m1 "^id:" "$adr" 2>/dev/null | sed 's/id:[[:space:]]*//' | tr -d '\r')
        if [ -n "$ADR_ID" ] && [ -f "docs/decisions/INDEX.md" ]; then
            if ! grep -q "$ADR_ID" docs/decisions/INDEX.md; then
                echo ""
                echo "ERROR: COMMIT BLOCCATO — ADR-0001 (INDEX.md)"
                echo "──────────────────────────────────────────────────────"
                echo "$ADR_ID non è referenziato in docs/decisions/INDEX.md."
                echo ""
                echo "Aggiorna INDEX.md prima di committare il nuovo ADR."
                echo "──────────────────────────────────────────────────────"
                echo ""
                exit 1
            fi
        fi
    done
fi

# ── Check 3: Pre-commit applicativo (ADR-0014, errata ADR-0006) ───────────────
# Se in staging ci sono file Python o pyproject.toml/uv.lock, invoca lo hook
# applicativo. Graceful skip se il file non esiste (fase pre-bootstrap o
# bootstrap minimo).
if [ "$HAS_PYTHON_STAGED" -eq 1 ]; then
    APP_HOOK="scripts/hooks/pre-commit-app"
    if [ -x "$APP_HOOK" ]; then
        "$APP_HOOK"
        APP_EXIT=$?
        if [ "$APP_EXIT" -ne 0 ]; then
            echo ""
            echo "ERROR: COMMIT BLOCCATO — ADR-0014 (pre-commit applicativo)"
            echo "──────────────────────────────────────────────────────"
            echo "Lo hook $APP_HOOK ha restituito exit $APP_EXIT."
            echo "──────────────────────────────────────────────────────"
            exit "$APP_EXIT"
        fi
    elif [ -f "$APP_HOOK" ]; then
        echo "WARNING: $APP_HOOK presente ma non eseguibile. Skip applicativo."
    fi
    # Se non esiste affatto: graceful skip (pre-bootstrap codice).
fi

exit 0
